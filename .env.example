# ─── Firebase ─────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → SDK config
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Google Gemini (optional — only needed for Receipt OCR) ───────────────────
# Get your API key from Google AI Studio: https://aistudio.google.com/app/apikey
# If not set, the "Scan Receipt" button will show an error and other features still work.

VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=your_gemini_model
